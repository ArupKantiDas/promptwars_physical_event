# GateFlow — Required Environment Variables
# Copy this file to .env.local and fill in all values before running the app.
# NEVER commit .env.local — it is already listed in .gitignore.

# ─── Gemini / Google AI ───────────────────────────────────────────────────────
# Obtain from: https://aistudio.google.com/app/apikey
# Required for the /api/chat conversational assistant.
GOOGLE_GEMINI_API_KEY=

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Client-side key — used by the Maps JavaScript API in VenueMap component.
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
# Restrict this key to HTTP referrers (your domain) and Maps JavaScript API.
NEXT_PUBLIC_MAPS_API_KEY=

# ─── Firebase Admin SDK (server-side only) ───────────────────────────────────
# Obtain from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# These values are NEVER exposed to the browser.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key including -----BEGIN/END PRIVATE KEY----- lines.
# Must be wrapped in double-quotes with literal \n for newlines:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ─── Firebase Client SDK (browser-side) ──────────────────────────────────────
# Obtain from: Firebase Console → Project Settings → General → Your apps → Web app
# These NEXT_PUBLIC_ values are safe to expose in the browser bundle.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── App Config ───────────────────────────────────────────────────────────────
# Firestore document ID of the active event. Must match a seeded events/{id} document.
# Run `npx tsx scripts/seed.ts` to populate Firestore with the demo event.
NEXT_PUBLIC_DEFAULT_EVENT_ID=ipl-final-2026
