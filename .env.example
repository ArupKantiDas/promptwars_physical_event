# GateFlow — Required Environment Variables
# Copy this file to .env.local and fill in all values before running the app.

# ─── Gemini / Google AI ───────────────────────────────────────────────────────
# Obtain from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# ─── Google Maps (client-side) ───────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com → Maps JavaScript API
NEXT_PUBLIC_MAPS_API_KEY=

# ─── Firebase Admin SDK (server-side) ────────────────────────────────────────
# Obtain from: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key, including -----BEGIN/END PRIVATE KEY----- lines.
# Wrap in double-quotes when setting in .env.local:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ─── Firebase Client SDK (browser-side) ──────────────────────────────────────
# Obtain from: Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── App Config ───────────────────────────────────────────────────────────────
# Firestore document ID of the active event. Defaults to 'ipl-final-2026' (seeded demo).
NEXT_PUBLIC_DEFAULT_EVENT_ID=ipl-final-2026
